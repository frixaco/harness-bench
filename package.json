{
  "name": "@frixaco/hbench",
  "version": "0.2.0",
  "type": "module",
  "bin": {
    "hbench": "./bin/hbench.js"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "bin",
    "dist",
    "README.md",
    "LICENSE*"
  ],
  "scripts": {
    "dev": "bun --hot server/index.ts",
    "start": "NODE_ENV=production bun --cwd dist index.js",
    "build": "bun run server/build.ts",
    "prepack": "bun run build",
    "format": "prettier --write .",
    "lint": "eslint",
    "lint-fix": "eslint --fix",
    "ts:ui": "bunx tsc -p ui/tsconfig.json --noEmit",
    "ts:api": "bunx tsc -p server/tsconfig.json --noEmit"
  },
  "dependencies": {
    "@ai-sdk/react": "^3.0.118",
    "@base-ui/react": "^1.3.0",
    "@openrouter/ai-sdk-provider": "^2.3.3",
    "@pierre/diffs": "^1.1.1",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-webgl": "^0.19.0",
    "@xterm/xterm": "^6.0.0",
    "ai": "^6.0.116",
    "bun-plugin-tailwind": "^0.1.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "effect": "^3.20.0",
    "ghostty-web": "^0.4.0",
    "lucide-react": "^0.577.0",
    "react": "^19",
    "react-dom": "^19",
    "restty": "^0.1.34",
    "sonner": "^2.0.7",
    "streamdown": "^2.5.0",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.2",
    "tw-animate-css": "^1.4.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@eslint/css": "^1.0.0",
    "@eslint/js": "^10.0.1",
    "@eslint/json": "^1.1.0",
    "@eslint/markdown": "^7.5.1",
    "@types/bun": "^1.3.11",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^10.0.3",
    "eslint-config-flat-gitignore": "^2.2.1",
    "eslint-plugin-react": "^7.37.5",
    "globals": "^17.4.0",
    "jiti": "^2.6.1",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "typescript-eslint": "^8.57.1"
  }
}
